{
    "name": "quickpay/php-sdk",
    "description": "Official PHP SDK for the Quickpay.ge payment gateway API",
    "type": "library",
    "license": "MIT",
    "keywords": ["quickpay", "payment", "georgia", "sdk", "api"],
    "homepage": "https://github.com/QuickPayGe/php-sdk",
    "support": {
        "source": "https://github.com/QuickPayGe/php-sdk",
        "issues": "https://github.com/QuickPayGe/php-sdk/issues"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Quickpay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Quickpay\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "version": "1.0.0"
}
